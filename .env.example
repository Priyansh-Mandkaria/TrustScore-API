# Database — set DB_ENGINE=mysql to use MySQL, or leave unset for SQLite fallback
DB_ENGINE=mysql
DB_NAME=trustscore_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Rate Limiting
THROTTLE_ANON=100/minute
THROTTLE_USER=200/minute
THROTTLE_EVALUATE=60/minute

# Django
DEBUG=True
SECRET_KEY=change-me-in-production
